#!/usr/bin/env bash
set -Eeuo pipefail

APP_NAME="warp-vps-manager"
APP_DIR="/opt/${APP_NAME}"
ETC_DIR="/etc/${APP_NAME}"
STATE_DIR="/var/lib/${APP_NAME}"
BACKUP_ROOT="/var/backups/${APP_NAME}"
CONFIG_FILE="${ETC_DIR}/config.env"
REDSOCKS_CONF="${ETC_DIR}/redsocks.conf"
NFT_CONF="${ETC_DIR}/nftables.conf"
RULES_DIR="${APP_DIR}/rules"
BIN_PATH="/usr/local/bin/warp-vps"
DEFAULT_WG_IFACE="warp-vps-wg"
DEFAULT_WGCF_BIN="${APP_DIR}/bin/wgcf"
DEFAULT_WG_CONFIG="/etc/wireguard/${DEFAULT_WG_IFACE}.conf"
DEFAULT_WGCF_VERSION="v2.2.31"
MANAGED_SWAP_FILE="/swapfile-warp-vps-manager"
REDSOCKS_FALLBACK_BIN="/usr/local/sbin/redsocks"
REDSOCKS_SOURCE_COMMIT="27b17889a43e32b0c1162514d00967e6967d41bb"
REDSOCKS_MANAGED_VERSION="redsocks/0.5-${REDSOCKS_SOURCE_COMMIT}"

if [ -t 1 ]; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_CYAN=$'\033[36m'
else
  C_RESET=''
  C_BOLD=''
  C_RED=''
  C_GREEN=''
  C_YELLOW=''
  C_CYAN=''
fi

log() { printf '[warp-vps] %s\n' "$*"; }
warn() { printf '[warp-vps] 警告：%s\n' "$*" >&2; }
die() { printf '[warp-vps] 错误：%s\n' "$*" >&2; exit 1; }

section() {
  printf '\n%b%s%b\n' "$C_BOLD" "$1" "$C_RESET"
}

info_line() {
  printf '%b%s%b %s\n' "$C_CYAN" "[信息]" "$C_RESET" "$1"
}

ok_line() {
  printf '%b%s%b %s\n' "$C_GREEN" "[通过]" "$C_RESET" "$1"
}

fail_line() {
  printf '%b%s%b %s\n' "$C_RED" "[失败]" "$C_RESET" "$1"
}

warn_line() {
  printf '%b%s%b %s\n' "$C_YELLOW" "[注意]" "$C_RESET" "$1"
}

require_root() {
  [ "$(id -u)" -eq 0 ] || die "请使用 root 用户运行"
}

load_config() {
  [ -r "$CONFIG_FILE" ] || die "找不到配置文件：$CONFIG_FILE"
  local line key value
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      ''|\#*) continue ;;
      *=*) ;;
      *) die "配置文件格式错误：$CONFIG_FILE: $line" ;;
    esac
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      APP_VERSION) APP_VERSION="$value" ;;
      REPO_RAW_BASE) REPO_RAW_BASE="$value" ;;
      WARP_MODE) WARP_MODE="$value" ;;
      WARP_SOCKS_PORT) WARP_SOCKS_PORT="$value" ;;
      REDSOCKS_PORT) REDSOCKS_PORT="$value" ;;
      REDSOCKS_USER) REDSOCKS_USER="$value" ;;
      REDSOCKS_UID) REDSOCKS_UID="$value" ;;
      REDSOCKS_GROUP) REDSOCKS_GROUP="$value" ;;
      REDSOCKS_BIN) REDSOCKS_BIN="$value" ;;
      WG_IFACE) WG_IFACE="$value" ;;
      WGCF_BIN) WGCF_BIN="$value" ;;
      WG_CONFIG) WG_CONFIG="$value" ;;
      MANAGED_WARP_SVC) MANAGED_WARP_SVC="$value" ;;
      MANAGED_REDSOCKS_BIN) MANAGED_REDSOCKS_BIN="$value" ;;
      *) die "配置文件存在未知字段：$key" ;;
    esac
  done < "$CONFIG_FILE"
  WARP_MODE="${WARP_MODE:-socks}"
  case "$WARP_MODE" in
    socks|wireguard) ;;
    *) die "配置里的 WARP_MODE 无效：$WARP_MODE" ;;
  esac
  WG_IFACE="${WG_IFACE:-$DEFAULT_WG_IFACE}"
  WGCF_BIN="${WGCF_BIN:-$DEFAULT_WGCF_BIN}"
  WG_CONFIG="${WG_CONFIG:-/etc/wireguard/${WG_IFACE}.conf}"
  [ -n "${WARP_SOCKS_PORT:-}" ] || WARP_SOCKS_PORT=0
  [ -n "${REDSOCKS_PORT:-}" ] || REDSOCKS_PORT=0
  [ -n "${REDSOCKS_USER:-}" ] || die "配置缺少 REDSOCKS_USER"
  [ -n "${REDSOCKS_UID:-}" ] || die "配置缺少 REDSOCKS_UID"
  REDSOCKS_GROUP="${REDSOCKS_GROUP:-$REDSOCKS_USER}"
  if [ -z "${MANAGED_WARP_SVC:-}" ]; then
    if [ "$WARP_MODE" = "socks" ]; then
      MANAGED_WARP_SVC=1
    else
      MANAGED_WARP_SVC=0
    fi
  fi
  if [ -z "${MANAGED_REDSOCKS_BIN:-}" ]; then
    MANAGED_REDSOCKS_BIN=0
    if [ "${REDSOCKS_BIN:-}" = "$REDSOCKS_FALLBACK_BIN" ] \
      && grep -aFq "$REDSOCKS_MANAGED_VERSION" "$REDSOCKS_FALLBACK_BIN" 2>/dev/null; then
      MANAGED_REDSOCKS_BIN=1
    fi
  fi
  [ -n "${REDSOCKS_GROUP:-}" ] || die "配置缺少 REDSOCKS_GROUP"
  [ -n "${REDSOCKS_BIN:-}" ] || die "配置缺少 REDSOCKS_BIN"
  [ -n "${REPO_RAW_BASE:-}" ] || die "配置缺少 REPO_RAW_BASE"
  if [ "$WARP_MODE" = "socks" ]; then
    valid_config_port "$WARP_SOCKS_PORT" || die "配置里的 WARP_SOCKS_PORT 不是有效端口"
    valid_config_port "$REDSOCKS_PORT" || die "配置里的 REDSOCKS_PORT 不是有效端口"
  fi
  case "$REDSOCKS_UID" in ''|*[!0-9]*) die "配置里的 REDSOCKS_UID 不是有效数字" ;; esac
  case "$MANAGED_WARP_SVC" in 0|1) ;; *) die "配置里的 MANAGED_WARP_SVC 不是有效值" ;; esac
  case "$MANAGED_REDSOCKS_BIN" in 0|1) ;; *) die "配置里的 MANAGED_REDSOCKS_BIN 不是有效值" ;; esac
  valid_config_name "$REDSOCKS_USER" || die "配置里的 REDSOCKS_USER 不是有效用户"
  valid_config_name "$REDSOCKS_GROUP" || die "配置里的 REDSOCKS_GROUP 不是有效用户组"
  valid_config_path "$REDSOCKS_BIN" || die "配置里的 REDSOCKS_BIN 不是安全绝对路径"
  valid_config_iface "$WG_IFACE" || die "配置里的 WG_IFACE 不是有效网卡名"
  valid_config_path "$WGCF_BIN" || die "配置里的 WGCF_BIN 不是安全绝对路径"
  valid_config_path "$WG_CONFIG" || die "配置里的 WG_CONFIG 不是安全绝对路径"
  validate_repo_raw_base "$REPO_RAW_BASE"
}

valid_config_port() {
  case "$1" in ''|*[!0-9]*) return 1 ;; esac
  [ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

valid_config_name() {
  case "$1" in
    ''|*[!A-Za-z0-9_.-]*) return 1 ;;
    *) return 0 ;;
  esac
}

valid_config_iface() {
  case "$1" in
    ''|*[!A-Za-z0-9_.:-]*) return 1 ;;
    *) [ "${#1}" -le 15 ] ;;
  esac
}

valid_config_path() {
  case "$1" in
    /*)
      case "$1" in *$'\n'*|*$'\r'*|*$'\t'*|*" "*) return 1 ;; esac
      return 0
      ;;
    *) return 1 ;;
  esac
}

validate_repo_raw_base() {
  local url="$1"
  [ -n "$url" ] || die "REPO_RAW_BASE 不能为空"
  case "$url" in
    https://*) ;;
    *) die "REPO_RAW_BASE 必须以 https:// 开头" ;;
  esac
  case "$url" in
    *$'\n'*|*$'\r'*|*$'\t'*|*" "*) die "REPO_RAW_BASE 不能包含空格或换行" ;;
  esac
  local rest="${url#https://}"
  local authority="${rest%%/*}"
  case "$authority" in
    *@*) die "REPO_RAW_BASE 不能包含账号密码信息" ;;
    '') die "REPO_RAW_BASE 缺少域名" ;;
  esac
}

raw_asset_url() {
  local rel="$1"
  local base="${REPO_RAW_BASE%/}"
  local url="${base}/${rel}"
  local sep="?"
  case "$url" in *\?*) sep="&" ;; esac
  printf '%s%swarp_vps_ts=%s\n' "$url" "$sep" "$(date -u +%s)"
}

mask_repo_url() {
  local url="$1"
  local rest authority
  rest="${url#https://}"
  authority="${rest%%/*}"
  if [ "$rest" = "$authority" ]; then
    printf 'https://%s\n' "$authority"
  else
    printf 'https://%s/%s\n' "$authority" "${rest#*/}"
  fi
}

validate_rules_file() {
  local file="$1"
  local version="$2"
  python3 - "$file" "$version" <<'PY'
import ipaddress
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
version = int(sys.argv[2])
seen = 0
for lineno, raw in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
    line = raw.strip()
    if not line or line.startswith("#"):
        continue
    if line != raw or any(ch.isspace() for ch in line):
        raise SystemExit(f"{path}:{lineno}: 存在非法空格")
    network = ipaddress.ip_network(line, strict=True)
    if network.version != version:
        raise SystemExit(f"{path}:{lineno}: 需要 IPv{version}，实际是 IPv{network.version}")
    seen += 1
if seen == 0:
    raise SystemExit(f"{path}: 规则为空")
PY
}

join_rules() {
  local file="$1"
  [ -r "$file" ] || die "找不到规则文件：$file"
  awk 'NF && $1 !~ /^#/ { printf "%s%s", sep, $1; sep=", " } END { print "" }' "$file"
}

render_redsocks_conf() {
  cat > "$REDSOCKS_CONF" <<EOF
base {
  log_debug = off;
  log_info = on;
  log = "syslog:daemon";
  daemon = off;
  redirector = iptables;
}

redsocks {
  local_ip = 127.0.0.1;
  local_port = ${REDSOCKS_PORT};
  ip = 127.0.0.1;
  port = ${WARP_SOCKS_PORT};
  type = socks5;
}
EOF
  chmod 0644 "$REDSOCKS_CONF"
}

render_nft_conf() {
  local google4 google6
  validate_rules_file "${RULES_DIR}/google_ipv4.txt" 4
  validate_rules_file "${RULES_DIR}/google_ipv6.txt" 6
  google4="$(join_rules "${RULES_DIR}/google_ipv4.txt")"
  google6="$(join_rules "${RULES_DIR}/google_ipv6.txt")"
  [ -n "$google4" ] || die "IPv4 规则为空"
  [ -n "$google6" ] || die "IPv6 规则为空"

  local table_action
  if table_exists; then
    table_action=$'delete table inet warp_vps\nadd table inet warp_vps'
  else
    table_action="add table inet warp_vps"
  fi

  cat > "$NFT_CONF" <<EOF
${table_action}
add set inet warp_vps google4 { type ipv4_addr; flags interval; auto-merge; elements = { ${google4} }; }
add set inet warp_vps google6 { type ipv6_addr; flags interval; auto-merge; elements = { ${google6} }; }
add chain inet warp_vps output_nat { type nat hook output priority -100; policy accept; }
add rule inet warp_vps output_nat meta skuid ${REDSOCKS_UID} return
add rule inet warp_vps output_nat oifname "lo" return
add rule inet warp_vps output_nat ip daddr { 0.0.0.0/8, 10.0.0.0/8, 100.64.0.0/10, 127.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12, 192.0.0.0/24, 192.0.2.0/24, 192.168.0.0/16, 198.18.0.0/15, 198.51.100.0/24, 203.0.113.0/24, 224.0.0.0/4, 240.0.0.0/4, 255.255.255.255/32 } return
add rule inet warp_vps output_nat ip daddr @google4 meta l4proto tcp counter redirect to :${REDSOCKS_PORT}
add chain inet warp_vps output_filter { type filter hook output priority filter; policy accept; }
add rule inet warp_vps output_filter meta skuid ${REDSOCKS_UID} return
add rule inet warp_vps output_filter oifname "lo" return
add rule inet warp_vps output_filter ip daddr @google4 udp dport 443 counter reject with icmpx type admin-prohibited
add rule inet warp_vps output_filter ip6 daddr @google6 counter reject with icmpx type admin-prohibited
EOF
  chmod 0644 "$NFT_CONF"
}

wg_interface_exists() {
  ip link show "$WG_IFACE" >/dev/null 2>&1
}

ipv6_route_required() {
  ip -6 route get 2001:4860:4860::8888 >/dev/null 2>&1 || ip -6 route show default 2>/dev/null | grep -q .
}

ssh_peer_ip() {
  [ -n "${SSH_CONNECTION:-}" ] || return 1
  printf '%s\n' "${SSH_CONNECTION%% *}"
}

ip_in_google_rules() {
  local ip="$1"
  python3 - "$ip" "${RULES_DIR}/google_ipv4.txt" "${RULES_DIR}/google_ipv6.txt" <<'PY'
import ipaddress
import pathlib
import sys

addr = ipaddress.ip_address(sys.argv[1])
for file_name in sys.argv[2:]:
    path = pathlib.Path(file_name)
    if not path.exists():
        continue
    for raw in path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if addr in ipaddress.ip_network(line, strict=True):
            raise SystemExit(2)
PY
}

protect_ssh_peer_route() {
  local peer rc
  peer="$(ssh_peer_ip || true)"
  [ -n "$peer" ] || return 0
  if ip_in_google_rules "$peer"; then
    return 0
  fi
  rc=$?
  if [ "$rc" -eq 2 ]; then
    die "当前 SSH 来源 IP 命中 Google 规则，WireGuard 路由可能导致 SSH 失联，已中止"
  fi
  die "无法完成 SSH 来源 IP 路由安全检查"
}

wgcf_asset_keyword() {
  case "$(uname -m)" in
    x86_64|amd64) printf 'linux_amd64\n' ;;
    aarch64|arm64) printf 'linux_arm64\n' ;;
    armv7l) printf 'linux_armv7\n' ;;
    armv6l) printf 'linux_armv6\n' ;;
    armv5*) printf 'linux_armv5\n' ;;
    i386|i686) printf 'linux_386\n' ;;
    *) die "WireGuard 模式暂不支持当前 CPU 架构：$(uname -m)" ;;
  esac
}

install_wgcf_binary() {
  [ -x "$WGCF_BIN" ] && return 0
  install -d -m 0755 "$(dirname "$WGCF_BIN")"
  local keyword wgcf_version
  keyword="$(wgcf_asset_keyword)"
  wgcf_version="${WARP_VPS_WGCF_VERSION:-$DEFAULT_WGCF_VERSION}"
  python3 - "$keyword" "$WGCF_BIN" "$wgcf_version" <<'PY'
import hashlib
import json
import os
import pathlib
import stat
import sys
import urllib.request

keyword = sys.argv[1]
dest = pathlib.Path(sys.argv[2])
version = sys.argv[3]
api_url = f"https://api.github.com/repos/ViRb3/wgcf/releases/tags/{version}"
with urllib.request.urlopen(api_url, timeout=30) as response:
    release = json.loads(response.read())
matches = [
    asset
    for asset in release.get("assets", [])
    if keyword in asset.get("name", "") and "sha" not in asset.get("name", "").lower()
]
if len(matches) != 1:
    raise SystemExit(f"无法确定 wgcf 下载地址，匹配数量：{len(matches)}")
checksum_assets = [
    asset for asset in release.get("assets", [])
    if asset.get("name") == "checksums.txt"
]
if len(checksum_assets) != 1:
    raise SystemExit("无法找到 wgcf checksums.txt")
asset = matches[0]
with urllib.request.urlopen(asset["browser_download_url"], timeout=120) as response:
    data = response.read()
with urllib.request.urlopen(checksum_assets[0]["browser_download_url"], timeout=30) as response:
    checksums = response.read().decode("utf-8", errors="replace").splitlines()
expected = None
for line in checksums:
    parts = line.split()
    if len(parts) >= 2 and parts[1] == asset["name"]:
        expected = parts[0].lower()
        break
actual = hashlib.sha256(data).hexdigest()
if not expected:
    raise SystemExit(f"checksums.txt 缺少 {asset['name']} 的校验值")
if actual != expected:
    raise SystemExit("wgcf 下载文件 SHA256 校验失败")
dest.write_bytes(data)
dest.chmod(dest.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
print(f"已下载并校验 wgcf：{release.get('tag_name', 'unknown')}")
PY
}

generate_wg_config() {
  [ -r "$WG_CONFIG" ] && return 0
  install -d -m 0700 /etc/wireguard "${STATE_DIR}/wgcf"
  install_wgcf_binary
  (
    cd "${STATE_DIR}/wgcf"
    if [ ! -s wgcf-account.toml ]; then
      printf 'yes\n' | "$WGCF_BIN" register >/dev/null
    fi
    "$WGCF_BIN" generate >/dev/null
  )
  [ -r "${STATE_DIR}/wgcf/wgcf-profile.conf" ] || die "wgcf 没有生成 WireGuard 配置"
  python3 - "${STATE_DIR}/wgcf/wgcf-profile.conf" "$WG_CONFIG" <<'PY'
import pathlib
import sys

src = pathlib.Path(sys.argv[1])
dst = pathlib.Path(sys.argv[2])
lines = src.read_text(encoding="utf-8").splitlines()
out = []
inserted = False
for line in lines:
    stripped = line.strip()
    if stripped.startswith("DNS"):
        continue
    if stripped.startswith("Table"):
        continue
    out.append(line)
    if stripped == "[Interface]" and not inserted:
        out.append("Table = off")
        inserted = True
if not inserted:
    raise SystemExit("WireGuard 配置缺少 [Interface]")
dst.write_text("\n".join(out).rstrip() + "\n", encoding="utf-8")
PY
  chmod 0600 "$WG_CONFIG"
}

route_file_lines() {
  local file="$1"
  awk 'NF && $1 !~ /^#/ { print $1 }' "$file"
}

apply_wg_routes() {
  load_config
  validate_rules_file "${RULES_DIR}/google_ipv4.txt" 4
  validate_rules_file "${RULES_DIR}/google_ipv6.txt" 6
  wg_interface_exists || die "WireGuard 网卡不存在：$WG_IFACE"
  protect_ssh_peer_route
  while IFS= read -r cidr; do
    ip -4 route replace "$cidr" dev "$WG_IFACE"
  done < <(route_file_lines "${RULES_DIR}/google_ipv4.txt")
  local require_ipv6 ipv6_failed
  require_ipv6=0
  ipv6_failed=0
  if ipv6_route_required; then
    require_ipv6=1
  fi
  while IFS= read -r cidr; do
    if ! ip -6 route replace "$cidr" dev "$WG_IFACE" 2>/dev/null; then
      ipv6_failed=1
    fi
  done < <(route_file_lines "${RULES_DIR}/google_ipv6.txt")
  if [ "$require_ipv6" -eq 1 ]; then
    [ "$ipv6_failed" -eq 0 ] || die "系统存在 IPv6 路由，但 Google IPv6 路由写入失败，已中止以避免泄漏"
    route_uses_wg6 2001:4860:4860::8888 || die "系统存在 IPv6 路由，但 Google IPv6 没有走 WireGuard，已中止以避免泄漏"
  fi
}

stop_wg_routes() {
  [ -r "${RULES_DIR}/google_ipv4.txt" ] || return 0
  while IFS= read -r cidr; do
    ip -4 route del "$cidr" dev "${WG_IFACE:-$DEFAULT_WG_IFACE}" 2>/dev/null || true
  done < <(route_file_lines "${RULES_DIR}/google_ipv4.txt")
  if [ -r "${RULES_DIR}/google_ipv6.txt" ]; then
    while IFS= read -r cidr; do
      ip -6 route del "$cidr" dev "${WG_IFACE:-$DEFAULT_WG_IFACE}" 2>/dev/null || true
    done < <(route_file_lines "${RULES_DIR}/google_ipv6.txt")
  fi
}

table_exists() {
  nft list table inet warp_vps >/dev/null 2>&1
}

apply_rules() {
  load_config
  validate_repo_raw_base "$REPO_RAW_BASE"
  install -d -m 0755 "$ETC_DIR"
  if [ "$WARP_MODE" = "wireguard" ]; then
    apply_wg_routes
    return
  fi
  render_redsocks_conf
  render_nft_conf
  nft -c -f "$NFT_CONF"
  nft -f "$NFT_CONF"
}

stop_rules() {
  if [ -r "$CONFIG_FILE" ]; then
    load_config
    if [ "$WARP_MODE" = "wireguard" ]; then
      stop_wg_routes
      return
    fi
  fi
  if table_exists; then
    nft delete table inet warp_vps
  fi
}

load_uninstall_config() {
  [ -r "$CONFIG_FILE" ] || return 0
  local line key value
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      WARP_MODE=*|WG_IFACE=*|MANAGED_WARP_SVC=*|REDSOCKS_BIN=*|MANAGED_REDSOCKS_BIN=*) ;;
      *) continue ;;
    esac
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      WARP_MODE)
        case "$value" in socks|wireguard) WARP_MODE="$value" ;; esac
        ;;
      WG_IFACE)
        if valid_config_iface "$value"; then
          WG_IFACE="$value"
        fi
        ;;
      MANAGED_WARP_SVC)
        case "$value" in 0|1) MANAGED_WARP_SVC="$value" ;; esac
        ;;
      REDSOCKS_BIN)
        if valid_config_path "$value"; then
          REDSOCKS_BIN="$value"
        fi
        ;;
      MANAGED_REDSOCKS_BIN)
        case "$value" in 0|1) MANAGED_REDSOCKS_BIN="$value" ;; esac
        ;;
    esac
  done < "$CONFIG_FILE"
  WG_IFACE="${WG_IFACE:-$DEFAULT_WG_IFACE}"
  WG_CONFIG="/etc/wireguard/${WG_IFACE}.conf"
  if [ -z "${MANAGED_WARP_SVC:-}" ]; then
    if [ "${WARP_MODE:-socks}" = "socks" ]; then
      MANAGED_WARP_SVC=1
    else
      MANAGED_WARP_SVC=0
    fi
  fi
  if [ -z "${MANAGED_REDSOCKS_BIN:-}" ]; then
    MANAGED_REDSOCKS_BIN=0
    if [ "${REDSOCKS_BIN:-}" = "$REDSOCKS_FALLBACK_BIN" ] \
      && grep -aFq "$REDSOCKS_MANAGED_VERSION" "$REDSOCKS_FALLBACK_BIN" 2>/dev/null; then
      MANAGED_REDSOCKS_BIN=1
    fi
  fi
}

stop_rules_for_uninstall() {
  stop_wg_routes
  if table_exists; then
    nft delete table inet warp_vps
  fi
}

install_systemd() {
  require_root
  load_config
  install -d -m 0755 "$ETC_DIR"
  if [ "$WARP_MODE" = "socks" ]; then
    render_redsocks_conf

    cat > /etc/systemd/system/warp-vps-redsocks.service <<EOF
[Unit]
Description=WARP VPS Manager redsocks 转发服务
After=network-online.target warp-svc.service
Wants=network-online.target

[Service]
Type=simple
User=${REDSOCKS_USER}
Group=${REDSOCKS_GROUP}
ExecStart=${REDSOCKS_BIN} -c ${REDSOCKS_CONF}
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict

[Install]
WantedBy=multi-user.target
EOF
  fi

  local route_after="network-online.target warp-svc.service warp-vps-redsocks.service"
  local route_wants="network-online.target warp-vps-redsocks.service"
  if [ "$WARP_MODE" = "wireguard" ]; then
    route_after="network-online.target wg-quick@${WG_IFACE}.service"
    route_wants="network-online.target wg-quick@${WG_IFACE}.service"
  fi

  cat > /etc/systemd/system/warp-vps.service <<EOF
[Unit]
Description=WARP VPS Manager Google 系统级分流
After=${route_after}
Wants=${route_wants}

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=${BIN_PATH} apply
ExecStop=${BIN_PATH} stop-rules

[Install]
WantedBy=multi-user.target
EOF

  cat > /etc/systemd/system/warp-vps-health.service <<EOF
[Unit]
Description=WARP VPS Manager 健康检查
After=network-online.target warp-vps.service

[Service]
Type=oneshot
ExecStart=${BIN_PATH} heal
EOF

  cat > /etc/systemd/system/warp-vps-health.timer <<'EOF'
[Unit]
Description=定时运行 WARP VPS Manager 健康检查

[Timer]
OnBootSec=2min
OnUnitActiveSec=5min
AccuracySec=30s
Persistent=false

[Install]
WantedBy=timers.target
EOF
}

port_listening() {
  ss -H -ltn "sport = :$1" 2>/dev/null | grep -q .
}

wait_for_socks_listen() {
  local max_wait="${1:-20}"
  local waited=0
  while [ "$waited" -lt "$max_wait" ]; do
    port_listening "$WARP_SOCKS_PORT" && return 0
    sleep 1
    waited=$((waited + 1))
  done
  port_listening "$WARP_SOCKS_PORT"
}

socks_trace() {
  curl --socks5-hostname "127.0.0.1:${WARP_SOCKS_PORT}" -fsS --connect-timeout 8 --max-time 15 \
    https://www.cloudflare.com/cdn-cgi/trace
}

socks_ok() {
  socks_trace 2>/dev/null | grep -Eq '^warp=(on|plus)$'
}

wg_ok() {
  wg_interface_exists || return 1
  curl -4 -fsS --connect-timeout 8 --max-time 15 -o /dev/null https://www.google.com/generate_204 >/dev/null 2>&1 || return 1
  local latest now
  latest="$(wg show "$WG_IFACE" latest-handshakes 2>/dev/null | awk 'NR == 1 { print $2 }')"
  case "$latest" in ''|*[!0-9]*) return 1 ;; esac
  [ "$latest" -gt 0 ] || return 1
  now="$(date +%s)"
  [ $((now - latest)) -lt 600 ]
}

wait_for_wg_ready() {
  local timeout="${1:-90}"
  local end=$((SECONDS + timeout))
  while [ "$SECONDS" -le "$end" ]; do
    if wg_interface_exists && route_uses_wg4 8.8.8.8 && wg_ok; then
      return 0
    fi
    sleep 2
  done
  return 1
}

restart_wireguard_runtime() {
  local attempt
  for attempt in 1 2; do
    systemctl restart "wg-quick@${WG_IFACE}.service" || return 1
    apply_rules || return 1
    if wait_for_wg_ready 90; then
      return 0
    fi
    warn_line "WireGuard 出口暂未就绪，正在重试"
  done
  return 1
}

route_uses_wg4() {
  ip -4 route get "$1" 2>/dev/null | grep -q "dev ${WG_IFACE}"
}

route_uses_wg6() {
  ip -6 route get "$1" 2>/dev/null | grep -q "dev ${WG_IFACE}"
}

google_counter() {
  nft list chain inet warp_vps output_nat 2>/dev/null \
    | awk '/redirect to :/ { for (i=1; i<=NF; i++) if ($i == "packets") { print $(i+1); exit } }'
}

service_active() {
  systemctl is-active --quiet "$1"
}

service_enabled() {
  systemctl is-enabled --quiet "$1"
}

unit_ready() {
  service_active "$1" && service_enabled "$1"
}

warp_cli() {
  timeout 60 warp-cli "$@"
}

ensure_warp_connected() {
  warp_cli --accept-tos tunnel protocol set MASQUE >/dev/null 2>&1 \
    || warp_cli tunnel protocol set MASQUE >/dev/null 2>&1 \
    || true
  warp_cli --accept-tos connect >/dev/null 2>&1 || warp_cli connect >/dev/null 2>&1 || true
}

test_quiet() {
  load_config
  if [ "$WARP_MODE" = "wireguard" ]; then
    wg_interface_exists || return 1
    wg_ok || return 1
    route_uses_wg4 8.8.8.8 || return 1
    curl -4 -fsS --connect-timeout 8 --max-time 15 -o /dev/null https://www.google.com/generate_204 >/dev/null 2>&1 || return 1
    if route_uses_wg4 1.1.1.1; then
      return 1
    fi
    if ipv6_route_required && ! route_uses_wg6 2001:4860:4860::8888; then
      return 1
    fi
    return 0
  fi
  wait_for_socks_listen 8 || return 1
  socks_ok || return 1
  service_active warp-vps-redsocks.service || return 1
  table_exists || return 1
  nft list chain inet warp_vps output_filter >/dev/null 2>&1 || return 1

  local before after
  before="$(google_counter)"
  [ -n "$before" ] || return 1
  curl -4 -fsS --connect-timeout 8 --max-time 15 -o /dev/null https://www.google.com/generate_204 >/dev/null 2>&1 || return 1
  after="$(google_counter)"
  [ -n "$after" ] || return 1
  [ "$after" -gt "$before" ] || return 1
}

print_rule_summary() {
  section "规则快照"
  if [ ! -r "${RULES_DIR}/rules.meta.json" ]; then
    warn_line "找不到规则快照：${RULES_DIR}/rules.meta.json"
    return 1
  fi
  python3 - "${RULES_DIR}/rules.meta.json" <<'PY' | while IFS= read -r line; do
import json
import pathlib
import sys

meta = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
source = meta.get("source", {})
print(f"Google 官方发布时间：{source.get('goog_creation_time', '未知')}")
print(f"本地规则生成时间：{meta.get('generated_at', '未知')}")
print(f"IPv4 规则数量：{meta.get('ipv4_count', '未知')}")
print(f"IPv6 规则数量：{meta.get('ipv6_count', '未知')}")
PY
    info_line "$line"
  done
}

run_self_check() {
  local failed=0
  local filter_rules=""
  local before after

  section "状态自检"
  if [ "$WARP_MODE" = "wireguard" ]; then
    info_line "当前模式：WireGuard 高级模式"
    info_line "WireGuard 网卡：${WG_IFACE}"

    if unit_ready "wg-quick@${WG_IFACE}.service"; then
      ok_line "WireGuard 开机服务正常"
    else
      fail_line "WireGuard 开机服务异常"
      failed=1
    fi

    if unit_ready warp-vps.service; then
      ok_line "分流规则服务正常"
    else
      fail_line "分流规则服务异常"
      failed=1
    fi

    if unit_ready warp-vps-health.timer; then
      ok_line "健康检查定时器正常"
    else
      fail_line "健康检查定时器异常"
      failed=1
    fi

    if wg_interface_exists; then
      ok_line "WireGuard 网卡已启动"
    else
      fail_line "WireGuard 网卡未启动"
      failed=1
    fi

    if wg_ok; then
      ok_line "WARP WireGuard 出口可用"
    else
      fail_line "WARP WireGuard 出口不可用"
      failed=1
    fi

    if route_uses_wg4 8.8.8.8; then
      ok_line "Google IPv4 路由已走 WARP"
    else
      fail_line "Google IPv4 路由没有走 WARP"
      failed=1
    fi

    if route_uses_wg4 1.1.1.1; then
      fail_line "普通 IPv4 流量也走了 WARP，分流异常"
      failed=1
    else
      ok_line "普通 IPv4 流量保持直连"
    fi

    if curl -4 -fsS --connect-timeout 8 --max-time 15 -o /dev/null https://www.google.com/generate_204 >/dev/null 2>&1; then
      ok_line "Google TCP 测试请求正常"
    else
      fail_line "Google TCP 测试请求失败"
      failed=1
    fi

    if route_uses_wg6 2001:4860:4860::8888; then
      ok_line "Google IPv6 路由已走 WARP"
    elif ipv6_route_required; then
      fail_line "系统存在 IPv6 路由，但 Google IPv6 没有走 WARP"
      failed=1
    else
      warn_line "未检测到 Google IPv6 路由命中，可能是系统没有 IPv6 或内核不支持"
    fi

    section "结论"
    if [ "$failed" -eq 0 ]; then
      ok_line "本机分流链路正常。命中规则的 Google 相关 TCP/UDP 流量会走 WARP。"
      return 0
    fi
    fail_line "当前异常。请先运行：warp-vps restart"
    warn_line "如果重启后仍失败，请运行：warp-vps logs"
    return 1
  fi

  info_line "WARP SOCKS 端口：${WARP_SOCKS_PORT}"

  if unit_ready warp-svc.service; then
    ok_line "WARP 官方客户端服务正常"
  else
    fail_line "WARP 官方客户端服务异常"
    failed=1
  fi

  if unit_ready warp-vps-redsocks.service; then
    ok_line "本地透明转发服务正常"
  else
    fail_line "本地透明转发服务异常"
    failed=1
  fi

  if unit_ready warp-vps.service; then
    ok_line "分流规则服务正常"
  else
    fail_line "分流规则服务异常"
    failed=1
  fi

  if unit_ready warp-vps-health.timer; then
    ok_line "健康检查定时器正常"
  else
    fail_line "健康检查定时器异常"
    failed=1
  fi

  if wait_for_socks_listen 8; then
    ok_line "WARP 本地 SOCKS 已启动"
  else
    fail_line "WARP 本地 SOCKS 没有监听"
    failed=1
  fi

  if socks_ok; then
    ok_line "WARP 出口可用"
  else
    fail_line "WARP 出口不可用"
    failed=1
  fi

  if service_active warp-vps-redsocks.service; then
    ok_line "本地透明转发进程正常"
  else
    fail_line "本地透明转发进程未运行"
    failed=1
  fi

  if table_exists; then
    ok_line "系统分流规则已加载"
  else
    fail_line "系统分流规则未加载"
    failed=1
  fi

  before="$(google_counter || true)"
  if [ -n "$before" ] && curl -4 -fsS --connect-timeout 8 --max-time 15 -o /dev/null https://www.google.com/generate_204 >/dev/null 2>&1; then
    after="$(google_counter || true)"
    if [ -n "$after" ] && [ "$after" -gt "$before" ]; then
      ok_line "Google 测试流量已走 WARP 分流"
    else
      fail_line "Google 测试流量没有命中分流规则"
      failed=1
    fi
  else
    fail_line "Google 测试请求失败"
    failed=1
  fi

  filter_rules="$(nft list chain inet warp_vps output_filter 2>/dev/null || true)"
  if grep -Eq 'udp dport 443.*reject' <<< "$filter_rules"; then
    ok_line "已阻断 Google/YouTube QUIC，防止 UDP 直连绕过"
  else
    fail_line "未找到 UDP/443 阻断规则"
    failed=1
  fi

  if grep -Eq 'ip6 daddr @google6.*reject' <<< "$filter_rules"; then
    ok_line "已阻断 Google 目标 IPv6，防止 IPv6 泄漏"
  else
    fail_line "未找到 Google IPv6 防泄漏规则"
    failed=1
  fi

  section "结论"
  if [ "$failed" -eq 0 ]; then
    ok_line "本机分流链路正常。命中规则的 Google 相关 IPv4 TCP 流量会走 WARP。"
    return 0
  fi

  fail_line "当前异常。请先运行：warp-vps restart"
  warn_line "如果重启后仍失败，请运行：warp-vps logs"
  return 1
}

cmd_test() {
  require_root
  load_config
  run_self_check
}

cmd_status() {
  require_root
  load_config
  section "当前配置"
  if [ "$WARP_MODE" = "wireguard" ]; then
    info_line "工作模式：WireGuard 高级模式，Google / YouTube / Gemini 的 TCP+UDP 走 WARP"
    info_line "WireGuard 网卡：${WG_IFACE}"
  else
    info_line "工作模式：Socks5 稳定模式，命中规则的 Google IPv4 TCP 走 WARP，UDP/443 阻断后通常回落"
    info_line "WARP SOCKS 端口：${WARP_SOCKS_PORT}"
    info_line "本地转发端口：${REDSOCKS_PORT}"
  fi
  info_line "更新地址：$(mask_repo_url "$REPO_RAW_BASE")"
  print_rule_summary || true
  run_self_check
}

cmd_restart() {
  require_root
  load_config
  section "正在重启"
  if [ "$WARP_MODE" = "wireguard" ]; then
    info_line "正在重启 WireGuard WARP 网卡和分流路由，请稍等"
    restart_wireguard_runtime || die "重启后 WireGuard 出口不可用"
    systemctl restart warp-vps.service
    cmd_test
    return
  fi

  info_line "正在重启 WARP 和本地分流服务，请稍等"
  systemctl restart warp-svc >/dev/null 2>&1 || true
  ensure_warp_connected
  wait_for_socks_listen 20 || die "重启后 WARP SOCKS 端口没有监听"
  systemctl restart warp-vps-redsocks.service
  apply_rules
  systemctl restart warp-vps.service
  cmd_test
}

cmd_setup_wireguard() {
  require_root
  load_config
  [ "$WARP_MODE" = "wireguard" ] || die "当前不是 WireGuard 模式"
  command -v wg >/dev/null 2>&1 || die "找不到 wg，请先安装 wireguard-tools"
  command -v wg-quick >/dev/null 2>&1 || die "找不到 wg-quick，请先安装 wireguard-tools"
  [ -c /dev/net/tun ] || die "当前系统没有可用 /dev/net/tun，不能使用 WireGuard 模式"
  generate_wg_config
  ok_line "WireGuard 配置已准备完成：${WG_CONFIG}"
}

cmd_preflight_wireguard() {
  require_root
  load_config
  [ "$WARP_MODE" = "wireguard" ] || die "当前不是 WireGuard 模式"
  [ -r "$WG_CONFIG" ] || die "找不到 WireGuard 配置：$WG_CONFIG"
  command -v wg-quick >/dev/null 2>&1 || die "找不到 wg-quick，请先安装 wireguard-tools"
  if wg_interface_exists; then
    die "WireGuard 网卡已经存在，不能执行安装前预检：$WG_IFACE"
  fi

  local failed
  failed=0
  info_line "正在临时拉起 WireGuard 网卡做路由预检"
  if ! wg-quick up "$WG_CONFIG"; then
    failed=1
  fi
  if [ "$failed" -eq 0 ]; then
    if ! "$BIN_PATH" apply; then
      failed=1
    elif ! test_quiet; then
      failed=1
    fi
  fi
  stop_wg_routes || true
  wg-quick down "$WG_IFACE" >/dev/null 2>&1 || true
  [ "$failed" -eq 0 ] || die "WireGuard 预检失败，未写入开机服务"
  ok_line "WireGuard 预检通过"
}

download_update_asset() {
  local rel="$1"
  local dest="$2"
  curl -fsSL "$(raw_asset_url "$rel")" -o "$dest"
}

validate_update_stage() {
  local stage="$1"
  bash -n "${stage}/install.sh"
  bash -n "${stage}/bin/warp-vps"
  validate_rules_file "${stage}/rules/google_ipv4.txt" 4
  validate_rules_file "${stage}/rules/google_ipv6.txt" 6
  python3 - "${stage}/rules/rules.meta.json" "${stage}/rules/google_ipv4.txt" "${stage}/rules/google_ipv6.txt" <<'PY'
import json
import pathlib
import sys

meta = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
ipv4 = [line for line in pathlib.Path(sys.argv[2]).read_text(encoding="utf-8").splitlines() if line.strip() and not line.startswith("#")]
ipv6 = [line for line in pathlib.Path(sys.argv[3]).read_text(encoding="utf-8").splitlines() if line.strip() and not line.startswith("#")]
if meta.get("ipv4_count") != len(ipv4):
    raise SystemExit("rules.meta.json 的 IPv4 数量不一致")
if meta.get("ipv6_count") != len(ipv6):
    raise SystemExit("rules.meta.json 的 IPv6 数量不一致")
PY
}

backup_current_installation() {
  local backup="$1"
  install -d -m 0755 "${backup}/bin" "${backup}/rules"
  [ -f "${APP_DIR}/install.sh" ] && install -m 0755 "${APP_DIR}/install.sh" "${backup}/install.sh"
  [ -f "${APP_DIR}/bin/warp-vps" ] && install -m 0755 "${APP_DIR}/bin/warp-vps" "${backup}/bin/warp-vps"
  [ -f "${RULES_DIR}/google_ipv4.txt" ] && install -m 0644 "${RULES_DIR}/google_ipv4.txt" "${backup}/rules/google_ipv4.txt"
  [ -f "${RULES_DIR}/google_ipv6.txt" ] && install -m 0644 "${RULES_DIR}/google_ipv6.txt" "${backup}/rules/google_ipv6.txt"
  [ -f "${RULES_DIR}/rules.meta.json" ] && install -m 0644 "${RULES_DIR}/rules.meta.json" "${backup}/rules/rules.meta.json"
  [ -f "$BIN_PATH" ] && install -m 0755 "$BIN_PATH" "${backup}/warp-vps"
}

activate_update_stage() {
  local stage="$1"
  install -m 0755 "${stage}/install.sh" "${APP_DIR}/install.sh"
  install -m 0755 "${stage}/bin/warp-vps" "${APP_DIR}/bin/warp-vps"
  install -m 0644 "${stage}/rules/google_ipv4.txt" "${RULES_DIR}/google_ipv4.txt"
  install -m 0644 "${stage}/rules/google_ipv6.txt" "${RULES_DIR}/google_ipv6.txt"
  install -m 0644 "${stage}/rules/rules.meta.json" "${RULES_DIR}/rules.meta.json"
  install -m 0755 "${APP_DIR}/bin/warp-vps" "$BIN_PATH"
}

restore_update_backup() {
  local backup="$1"
  [ -f "${backup}/install.sh" ] && install -m 0755 "${backup}/install.sh" "${APP_DIR}/install.sh"
  [ -f "${backup}/bin/warp-vps" ] && install -m 0755 "${backup}/bin/warp-vps" "${APP_DIR}/bin/warp-vps"
  [ -f "${backup}/rules/google_ipv4.txt" ] && install -m 0644 "${backup}/rules/google_ipv4.txt" "${RULES_DIR}/google_ipv4.txt"
  [ -f "${backup}/rules/google_ipv6.txt" ] && install -m 0644 "${backup}/rules/google_ipv6.txt" "${RULES_DIR}/google_ipv6.txt"
  [ -f "${backup}/rules/rules.meta.json" ] && install -m 0644 "${backup}/rules/rules.meta.json" "${RULES_DIR}/rules.meta.json"
  [ -f "${backup}/warp-vps" ] && install -m 0755 "${backup}/warp-vps" "$BIN_PATH"
}

reload_runtime_after_update() {
  "$BIN_PATH" install-systemd || return 1
  systemctl daemon-reload || return 1
  if [ "$WARP_MODE" = "wireguard" ]; then
    systemctl enable "wg-quick@${WG_IFACE}.service" warp-vps.service warp-vps-health.timer >/dev/null || return 1
    restart_wireguard_runtime || return 1
  else
    systemctl enable warp-svc.service warp-vps-redsocks.service warp-vps.service warp-vps-health.timer >/dev/null || return 1
    "$BIN_PATH" apply || return 1
    systemctl restart warp-vps-redsocks.service || return 1
  fi
  systemctl restart warp-vps.service || return 1
  "$BIN_PATH" test || return 1
}

cmd_update() {
  require_root
  load_config
  local stage="${STATE_DIR}/downloads/$(date -u +%Y%m%dT%H%M%SZ)"
  local backup="${STATE_DIR}/rollback/$(date -u +%Y%m%dT%H%M%SZ)"
  section "正在更新"
  info_line "正在从 GitHub 同步脚本和固定规则快照"
  install -d -m 0755 "${stage}/bin" "${stage}/rules"
  download_update_asset "install.sh" "${stage}/install.sh"
  download_update_asset "bin/warp-vps" "${stage}/bin/warp-vps"
  download_update_asset "rules/google_ipv4.txt" "${stage}/rules/google_ipv4.txt"
  download_update_asset "rules/google_ipv6.txt" "${stage}/rules/google_ipv6.txt"
  download_update_asset "rules/rules.meta.json" "${stage}/rules/rules.meta.json"
  validate_update_stage "$stage"
  backup_current_installation "$backup"
  activate_update_stage "$stage"
  ok_line "更新完成，正在运行自检"
  if reload_runtime_after_update; then
    ok_line "更新后的链路自检通过"
    return 0
  fi

  warn_line "更新后自检失败，正在恢复旧版本"
  restore_update_backup "$backup"
  if reload_runtime_after_update; then
    die "更新失败，已恢复旧版本"
  fi
  die "更新失败，且恢复旧版本后自检仍失败，请运行 warp-vps logs 查看日志"
}

cmd_heal() {
  require_root
  if test_quiet; then
    log "健康检查正常"
    return 0
  fi
  warn "健康检查失败，正在尝试自动修复"
  load_config
  if [ "$WARP_MODE" = "wireguard" ]; then
    restart_wireguard_runtime || true
    if test_quiet; then
      log "自动修复成功"
    else
      die "自动修复失败，请运行 warp-vps logs 查看日志"
    fi
    return 0
  fi
  systemctl restart warp-svc >/dev/null 2>&1 || true
  ensure_warp_connected
  wait_for_socks_listen 20 || die "自动修复后 WARP SOCKS 端口仍未监听"
  systemctl restart warp-vps-redsocks.service || true
  apply_rules
  if test_quiet; then
    log "自动修复成功"
  else
    die "自动修复失败，请运行 warp-vps logs 查看日志"
  fi
}

cmd_wait_wireguard() {
  require_root
  load_config
  [ "$WARP_MODE" = "wireguard" ] || die "当前不是 WireGuard 模式"
  wait_for_wg_ready 90
}

cmd_logs() {
  require_root
  journalctl -u warp-svc -u "wg-quick@${DEFAULT_WG_IFACE}.service" -u warp-vps-redsocks.service -u warp-vps.service -u warp-vps-health.service --no-pager -n 200
}

safe_move_if_exists() {
  local path="$1"
  local backup_dir="$2"
  local label="$3"
  local dest="${backup_dir}/${label}"
  [ -e "$path" ] || return 0
  [ ! -e "$dest" ] || die "备份目标已存在：$dest"
  mv "$path" "$dest"
}

print_move_target_if_exists() {
  local path="$1"
  local backup_dir="$2"
  local label="$3"
  [ -e "$path" ] || return 0
  info_line "$path -> ${backup_dir}/${label}"
}

uninstall_managed_swap() {
  local backup_dir="$1"
  if grep -qF "$MANAGED_SWAP_FILE" /proc/swaps 2>/dev/null; then
    info_line "正在停用本脚本创建的 Swap：$MANAGED_SWAP_FILE"
    swapoff "$MANAGED_SWAP_FILE"
  fi
  if grep -qF "$MANAGED_SWAP_FILE" /etc/fstab 2>/dev/null; then
    info_line "正在从 /etc/fstab 移除本脚本创建的 Swap 记录，原文件会备份"
    install -m 0644 /etc/fstab "${backup_dir}/fstab.before-warp-vps"
    awk -v swap_file="$MANAGED_SWAP_FILE" '$1 != swap_file { print }' /etc/fstab > "${backup_dir}/fstab.cleaned"
    install -m 0644 "${backup_dir}/fstab.cleaned" /etc/fstab
  fi
  safe_move_if_exists "$MANAGED_SWAP_FILE" "$backup_dir" "swapfile-warp-vps-manager"
}

disable_managed_warp_service() {
  [ "${MANAGED_WARP_SVC:-0}" = "1" ] || return 0
  info_line "正在停止 Cloudflare WARP 官方客户端服务"
  systemctl stop warp-svc >/dev/null 2>&1 || true
  systemctl disable warp-svc >/dev/null 2>&1 || true
}

ensure_wireguard_down_for_uninstall() {
  [ "${WARP_MODE:-socks}" = "wireguard" ] || return 0
  wg_interface_exists || return 0
  info_line "正在关闭 WireGuard 网卡：${WG_IFACE:-$DEFAULT_WG_IFACE}"
  if command -v wg-quick >/dev/null 2>&1 && [ -r "${WG_CONFIG:-$DEFAULT_WG_CONFIG}" ]; then
    wg-quick down "${WG_CONFIG:-$DEFAULT_WG_CONFIG}" >/dev/null 2>&1 \
      || wg-quick down "${WG_IFACE:-$DEFAULT_WG_IFACE}" >/dev/null 2>&1 \
      || true
  fi
  if wg_interface_exists; then
    die "WireGuard 网卡仍在运行，卸载已中止：${WG_IFACE:-$DEFAULT_WG_IFACE}"
  fi
}

managed_redsocks_fallback_exists() {
  [ "${MANAGED_REDSOCKS_BIN:-0}" = "1" ] || return 1
  [ "${REDSOCKS_BIN:-}" = "$REDSOCKS_FALLBACK_BIN" ] || return 1
  [ -e "$REDSOCKS_FALLBACK_BIN" ]
}

cmd_uninstall() {
  require_root
  local backup_dir="${BACKUP_ROOT}/uninstall-$(date -u +%Y%m%dT%H%M%SZ)"
  install -d -m 0755 "$backup_dir"
  load_uninstall_config
  systemctl stop warp-vps-health.timer warp-vps.service warp-vps-redsocks.service "wg-quick@${WG_IFACE:-$DEFAULT_WG_IFACE}.service" >/dev/null 2>&1 || true
  systemctl disable warp-vps-health.timer warp-vps.service warp-vps-redsocks.service "wg-quick@${WG_IFACE:-$DEFAULT_WG_IFACE}.service" >/dev/null 2>&1 || true
  ensure_wireguard_down_for_uninstall
  stop_rules_for_uninstall
  disable_managed_warp_service

  section "卸载移动清单"
  info_line "以下项目文件会移动到备份目录，不会永久删除"
  print_move_target_if_exists /etc/systemd/system/warp-vps-redsocks.service "$backup_dir" "systemd-warp-vps-redsocks.service"
  print_move_target_if_exists /etc/systemd/system/warp-vps.service "$backup_dir" "systemd-warp-vps.service"
  print_move_target_if_exists /etc/systemd/system/warp-vps-health.service "$backup_dir" "systemd-warp-vps-health.service"
  print_move_target_if_exists /etc/systemd/system/warp-vps-health.timer "$backup_dir" "systemd-warp-vps-health.timer"
  print_move_target_if_exists "${WG_CONFIG:-$DEFAULT_WG_CONFIG}" "$backup_dir" "wireguard-${WG_IFACE:-$DEFAULT_WG_IFACE}.conf"
  print_move_target_if_exists "$ETC_DIR" "$backup_dir" "etc-warp-vps-manager"
  print_move_target_if_exists "$APP_DIR" "$backup_dir" "opt-warp-vps-manager"
  print_move_target_if_exists "$STATE_DIR" "$backup_dir" "var-lib-warp-vps-manager"
  print_move_target_if_exists "$BIN_PATH" "$backup_dir" "usr-local-bin-warp-vps"
  if managed_redsocks_fallback_exists; then
    print_move_target_if_exists "$REDSOCKS_FALLBACK_BIN" "$backup_dir" "usr-local-sbin-redsocks"
  fi
  print_move_target_if_exists "$MANAGED_SWAP_FILE" "$backup_dir" "swapfile-warp-vps-manager"

  uninstall_managed_swap "$backup_dir"
  safe_move_if_exists /etc/systemd/system/warp-vps-redsocks.service "$backup_dir" "systemd-warp-vps-redsocks.service"
  safe_move_if_exists /etc/systemd/system/warp-vps.service "$backup_dir" "systemd-warp-vps.service"
  safe_move_if_exists /etc/systemd/system/warp-vps-health.service "$backup_dir" "systemd-warp-vps-health.service"
  safe_move_if_exists /etc/systemd/system/warp-vps-health.timer "$backup_dir" "systemd-warp-vps-health.timer"
  safe_move_if_exists "${WG_CONFIG:-$DEFAULT_WG_CONFIG}" "$backup_dir" "wireguard-${WG_IFACE:-$DEFAULT_WG_IFACE}.conf"
  safe_move_if_exists "$ETC_DIR" "$backup_dir" "etc-warp-vps-manager"
  safe_move_if_exists "$APP_DIR" "$backup_dir" "opt-warp-vps-manager"
  safe_move_if_exists "$STATE_DIR" "$backup_dir" "var-lib-warp-vps-manager"
  safe_move_if_exists "$BIN_PATH" "$backup_dir" "usr-local-bin-warp-vps"
  if managed_redsocks_fallback_exists; then
    safe_move_if_exists "$REDSOCKS_FALLBACK_BIN" "$backup_dir" "usr-local-sbin-redsocks"
  fi
  systemctl daemon-reload
  printf 'WARP VPS Manager 已卸载，文件已移动到备份目录：%s\n' "$backup_dir"
  printf '系统依赖包已保留，不会被删除。\n'
}

usage() {
  cat <<'EOF'
用法：warp-vps <命令>

常用命令：
  status          查看中文状态自检
  test            运行一次中文自检
  restart         重启 WARP 分流链路
  update          更新脚本和固定规则快照
  logs            查看最近日志
  uninstall       卸载并移动文件到备份目录

内部命令：
  heal            健康检查和自动修复
  apply           重新生成并加载分流规则
  stop-rules      移除本项目 nftables 规则
  setup-wireguard 准备 WireGuard WARP 配置
  preflight-wireguard 预检 WireGuard 网卡和路由
  wait-wireguard  等待 WireGuard 出口就绪
  install-systemd 安装 systemd 服务
EOF
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    status) cmd_status ;;
    test) cmd_test ;;
    restart) cmd_restart ;;
    update) cmd_update ;;
    logs) cmd_logs ;;
    heal) cmd_heal ;;
    apply) require_root; apply_rules ;;
    stop-rules) require_root; stop_rules ;;
    setup-wireguard) cmd_setup_wireguard ;;
    preflight-wireguard) cmd_preflight_wireguard ;;
    wait-wireguard) cmd_wait_wireguard ;;
    install-systemd) install_systemd ;;
    uninstall) cmd_uninstall ;;
    -h|--help|help|'') usage ;;
    *) usage; exit 2 ;;
  esac
}

main "$@"
